</ol></li>
<li local-id=3D"36b3a17c-4c3f-4cc3-9727-490e656adf59">
<p local-id=3D"4211940c-d700-4e67-b7b0-86d21c46fc18"><a href=3D"https://tbi=
group.atlassian.net/wiki/spaces/TSFMPU/pages/4053106704/API+documentation+-=
+Fusion+Pay#Ready-Embedded-Calculator" rel=3D"nofollow"><strong>Ready embed=
ded calculator</strong></a></p></li>
<li local-id=3D"f9147510-e269-41c8-b941-42dbf56bc314">
<p local-id=3D"cb13dc35-4524-4f97-9b77-bda647be4f5b"><a href=3D"https://tbi=
group.atlassian.net/wiki/spaces/TSFMPU/pages/4053106704/API+documentation+-=
+Fusion+Pay#Express-Buy-Button-Integration-on-Product-Page" rel=3D"nofollow=
"><strong>Express buy button in product page</strong></a></p></li>
<li local-id=3D"42456b29-727c-4ea6-a0de-2c126133cc8a">
<p local-id=3D"b554cb98-f8b8-4847-b688-36c2b501eebd"><a href=3D"https://tbi=
